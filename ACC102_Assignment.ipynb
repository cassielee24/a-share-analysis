    "# Fetch financial data (remove prc and cshr filter conditions)\n",
    "query_funda = \"\"\"\n",
    "SELECT gvkey, conm, sich, ibc, ceq\n",
    "FROM comp.g_funda\n",
    "WHERE loc = 'CHN' \n",
    "    AND fyear = 2024\n",
    "    AND indfmt = 'INDL'\n",
    "    AND consol = 'C'\n",
    "    AND ibc > 0\n",
    "    AND ceq > 0\n",
    "\"\"\"\n",
    "\n",
    "df_funda = db.raw_sql(query_funda)\n",
    "print(f\"✅ Financial data：{len(df_funda)} \")\n",
    "\n",
    "#Merge\n",
    "df_merged = df_funda.merge(df_price_unique, on='gvkey', how='inner')\n",
    "print(f\"✅ After merging：{len(df_merged)} records\")\n",
    "df_merged.head()"
   ]
  },
