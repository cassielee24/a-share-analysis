   "source": [
    # Calculate ROE (Return on Equity) = Net Income / Equity * 100
df_merged['roe'] = (df_merged['ibc'] / df_merged['ceq']) * 100

# Calculate Market Cap = Price × Shares Outstanding
df_merged['market_cap'] = df_merged['prccd'] * df_merged['cshoc']

# Calculate PE (Price-to-Earnings) = Market Cap / Net Income
df_merged['pe'] = df_merged['market_cap'] / df_merged['ibc']

# Remove outliers: PE between 0 and 200
df_clean = df_merged[(df_merged['pe'] > 0) & (df_merged['pe'] < 200)]

print(f"✅ After cleaning: {len(df_clean)} records")
df_clean[['conm', 'roe', 'pe']].head()
   ]
