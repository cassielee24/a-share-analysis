    # Use WRDS comp_na_daily view (North American company data, includes Chinese ADRs)
# If we strictly want A-shares, use directly comp_global_daily\n",
    "query = \"\"\"\n",
    "SELECT \n",
    "    gvkey,\n",
    "    datadate,\n",
    "    fyear,\n",
    "    tic,\n",
    "    conm,\n",
    "    curcd,\n",
    "    at,          -- Total Assets\n",
    "    lt,          -- Total Liabilities\n",
    "    sale,        -- Revenue\n",
    "    ni,          -- Net Income\n",
    "    ceq,         -- Common Equity\n",
    "    prccd,       -- Closing Price\n",
    "    csho,        -- Share Outstanding\n",
    "    epspx,       -- Earnings Per Share\n",
    "    sich         -- Industry Code\n",
    "FROM comp_global_daily\n",
    "WHERE loc = 'CHN'\n",
    "    AND fyear = 2024\n",
    "    AND curcd = 'CNY'\n",
    "LIMIT 100\n",
    "\"\"\"\n",
    "\n",
    "# Execute query\n",
    "df = db.raw_sql(query)\n",
    "\n",
    "print(f\"✅ Fetched {len(df)} records\")\n",
    "print(f\"Covering {df['conm'].nunique()} companies\")\n",
    "\n",
    "# Display data\n",
    "df.head()"
   ]
  },
